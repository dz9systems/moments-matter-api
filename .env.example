# Copy to .env and fill in values. Do not commit .env.

# Local: path to service account file (gitignored)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Render / cloud: paste entire service-account JSON as one line (do not use file path)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
OPENAI_API_KEY=
# Comma-separated origins, or * for any (dev only)
CORS_ORIGIN=http://localhost:5173

# Magic Patterns (*.magicpatterns.app) allowed by default. Set to 0 to disable.
# CORS_ALLOW_MAGIC_PATTERNS=0

PORT=3000
